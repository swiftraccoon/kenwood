<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Allow this app to open IOUserClient connections to the Lodestar
	     dext. The bundle ID listed must match the dext exactly. -->
	<key>com.apple.developer.driverkit.userclient-access</key>
	<array>
		<string>org.swiftraccoon.lodestar.ipad.driver</string>
	</array>
</dict>
</plist>
